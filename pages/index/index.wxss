.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 20rpx;
  box-sizing: border-box;
}

.score-board {
  display: flex;
  justify-content: space-around;
  width: 100%;
  max-width: 600rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
}

.score-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #2ecc71;
}

.game-canvas {
  width: 600rpx;
  height: 600rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
  background: #1a1a2e;
}

.game-info {
  margin-top: 30rpx;
  margin-bottom: 20rpx;
}

.info-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.start-btn {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(46, 204, 113, 0.4);
}

.start-btn[disabled] {
  background: linear-gradient(135deg, #95a5a6 0%, #7f8c8d 100%);
  box-shadow: none;
}

.start-btn::after {
  border: none;
}

/* 方向控制按钮 */
.direction-controls {
  margin-top: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.direction-row {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin: 10rpx 0;
}

.direction-btn {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(46, 204, 113, 0.2);
  border-radius: 50%;
  border: 4rpx solid rgba(46, 204, 113, 0.5);
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.3);
  transition: all 0.1s ease;
}

.direction-btn:active {
  background: rgba(46, 204, 113, 0.4);
  transform: scale(0.9);
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
}

.direction-icon {
  font-size: 48rpx;
  color: #2ecc71;
  font-weight: bold;
  line-height: 1;
}
