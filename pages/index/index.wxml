<view class="container">
  <view class="score-board">
    <view class="score-item">
      <text class="score-label">当前分数</text>
      <text class="score-value">{{score}}</text>
    </view>
    <view class="score-item">
      <text class="score-label">最高分</text>
      <text class="score-value">{{highestScore}}</text>
    </view>
  </view>

  <canvas 
    type="2d" 
    id="gameCanvas" 
    class="game-canvas"
  ></canvas>

  <view class="game-info">
    <text class="info-text">👆 滑动屏幕 或 点击方向键控制</text>
  </view>

  <!-- 方向控制按钮（备用方案） -->
  <view class="direction-controls" wx:if="{{isGameRunning || isGameOver}}">
    <view class="direction-row">
      <view 
        class="direction-btn" 
        data-dir="up"
        bindtap="onDirectionTap"
      >
        <text class="direction-icon">▲</text>
      </view>
    </view>
    <view class="direction-row">
      <view 
        class="direction-btn" 
        data-dir="left"
        bindtap="onDirectionTap"
      >
        <text class="direction-icon">◀</text>
      </view>
      <view 
        class="direction-btn" 
        data-dir="down"
        bindtap="onDirectionTap"
      >
        <text class="direction-icon">▼</text>
      </view>
      <view 
        class="direction-btn" 
        data-dir="right"
        bindtap="onDirectionTap"
      >
        <text class="direction-icon">▶</text>
      </view>
    </view>
  </view>

  <button 
    class="start-btn" 
    bindtap="onStartTap"
    disabled="{{isGameRunning}}"
  >
    {{isGameRunning ? '游戏中...' : (isGameOver ? '重新开始' : '开始游戏')}}
  </button>
</view>
